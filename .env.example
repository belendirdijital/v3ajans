# Admin panel güvenlik secret'ı - Vercel'de mutlaka ayarla
# Güçlü bir rastgele string kullan (örn: openssl rand -hex 32)
ADMIN_SECRET=your-secure-secret-here

# Neon Postgres - Vercel deploy için zorunlu
# Kurulum: Vercel Dashboard > Storage > Marketplace > Neon > Add Integration
# Yerel geliştirme: .env.local dosyasına DATABASE_URL ekle (Neon Dashboard'dan al)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
